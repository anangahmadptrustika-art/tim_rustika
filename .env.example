# ---------------------------------------------------------------------------
# Rustika PMS — Environment Variables
# Copy to `.env` and fill in. Never commit the real `.env`.
# ---------------------------------------------------------------------------

# Database (PostgreSQL)
DATABASE_URL="postgresql://rustika:rustika@localhost:5432/rustika?schema=public"

# NextAuth / Auth.js
# Generate: `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"
PORT="3000"

# Email (SMTP) — optional, mock logging used if unset
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Rustika PMS <no-reply@rustika.co.id>"

# WhatsApp Cloud API — optional, mock logging used if unset
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""

# File storage (S3-compatible) — optional
S3_ENDPOINT=""
S3_BUCKET="rustika-attachments"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
